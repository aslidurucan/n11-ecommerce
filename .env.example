# ============================================================
# Gerekli ortam değişkenleri — gerçek değerleri .env'e kopyala
# Bu dosya commitleniyor, gerçek değer YAZMA!
# ============================================================

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-strong-password

# Keycloak Admin
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=your-strong-password

# Iyzico — https://sandbox-merchant.iyzipay.com adresinden al
IYZICO_API_KEY=sandbox-xxxxxxxxxxxxxxxxxxxx
IYZICO_SECRET_KEY=sandbox-xxxxxxxxxxxxxxxxxxxx

# Mail (notification-service)
MAIL_PASSWORD=your-mail-app-password

GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.1-8b-instant
